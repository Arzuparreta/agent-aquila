# Copy to `.env` for `docker compose up` (Postgres, JWT, Redis). Connector OAuth (Google / Microsoft)
# is configured in the app: Settings → External connectors — no OAuth variables are required here.
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
# Full URL (optional). If set, it is used as-is — percent-encode user/password if they contain @ : # etc.
# `docker compose` sets DATABASE_URL empty and POSTGRES_HOST=db so the app builds an encoded URL from POSTGRES_*.
# For uvicorn on the host against Compose Postgres on 5433, use e.g.:
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@127.0.0.1:5433/crm_db
# POSTGRES_HOST=localhost
JWT_SECRET=change_me_in_production
# Optional: Fernet urlsafe base64 key for encrypting per-user API keys (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Add your LAN/Tailscale UI origin if the browser ever calls the API on :8000 directly (prefer same-origin /api/v1).
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
# Browser uses same-origin /api/v1 (Next.js rewrites to the API). For `npm run dev` on the host, set:
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=/api/v1
# Agent / safety (optional)
# AGENT_EMAIL_DOMAIN_ALLOWLIST=yourband.com,partner.com
# AGENT_MAX_RUNS_PER_HOUR=60
# AGENT_MAX_TOOL_STEPS=10
# EMAIL_INGEST_AUTO_CREATE_DEALS=true

# --- Redis (required for background Gmail/Calendar/Drive sync workers) ---
REDIS_URL=redis://redis:6379/0

# --- Google OAuth (optional legacy fallback only) ---
# UI path: Settings → External connectors. Leave empty when using the in-app form.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Used only when the database has no "public URL" saved yet (prefer setting Public URL in the UI).
GOOGLE_OAUTH_REDIRECT_BASE=http://localhost:8000
OAUTH_POST_AUTH_REDIRECT=http://localhost:3002/settings

# --- Microsoft Graph OAuth (optional legacy fallback only) ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# --- Sync worker tuning ---
GMAIL_INITIAL_SYNC_MAX_MESSAGES=2000
GMAIL_DELTA_POLL_SECONDS=120
CALENDAR_DELTA_POLL_SECONDS=300
DRIVE_DELTA_POLL_SECONDS=300
