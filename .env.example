# Copy to `.env` for `docker compose up` (Postgres, JWT, Redis). Connector OAuth (Google / Microsoft)
# is configured in the app: Settings → External connectors — no OAuth variables are required here.
POSTGRES_USER=aquila_user
POSTGRES_PASSWORD=aquila_password
POSTGRES_DB=aquila_db
# Full URL (optional). If set, it is used as-is — percent-encode user/password if they contain @ : # etc.
# `docker compose` sets DATABASE_URL empty and POSTGRES_HOST=db so the app builds an encoded URL from POSTGRES_*.
# For uvicorn on the host against Compose Postgres on 5433, use e.g.:
DATABASE_URL=postgresql+asyncpg://aquila_user:aquila_password@127.0.0.1:5433/aquila_db
# POSTGRES_HOST=localhost
JWT_SECRET=change_me_in_production
# Optional: Fernet urlsafe base64 key for encrypting per-user API keys (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Signups: set REGISTRATION_OPEN=false after your account exists (stops drive-by /api/v1/auth/register).
# Optional: only allow your domain(s), e.g. REGISTRATION_EMAIL_DOMAIN_ALLOWLIST=example.com
# Optional: single-tenant — REGISTRATION_MAX_USERS=1 allows only the first account ever.
# REGISTRATION_OPEN=true
# REGISTRATION_EMAIL_DOMAIN_ALLOWLIST=
# REGISTRATION_MAX_USERS=0
# Add your LAN/Tailscale UI origin if the browser ever calls the API on :8000 directly (prefer same-origin /api/v1).
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
# Browser uses same-origin /api/v1 (Next.js rewrites to the API). For `npm run dev` on the host, set:
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=/api/v1
# Agent / safety (optional)
# AGENT_EMAIL_DOMAIN_ALLOWLIST=yourband.com,partner.com
# AGENT_MAX_RUNS_PER_HOUR=60
# LLM turns per chat message (raise for heavy multi-tool tasks; max 100).
# AGENT_MAX_TOOL_STEPS=25
# When true and REDIS_URL is set, chat agent runs in the ARQ worker (recommended in Docker).
# AGENT_ASYNC_RUNS=true
# Optional: call API directly from the browser (bypass Next rewrites). Add UI origin to CORS_ORIGINS.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
# Smaller tool palette for lower prompt tokens: full | compact (see agent_tools.tools_for_palette_mode).
# AGENT_TOOL_PALETTE=full
# Prompt assembly: full | minimal | none (smaller system prompts; see agent_workspace.build_system_prompt).
# AGENT_PROMPT_TIER=full
# AGENT_INCLUDE_HARNESS_FACTS=true
# Omit tools for disconnected connectors (reduces tokens; enable when users understand linking).
# AGENT_CONNECTOR_GATED_TOOLS=false
# Tighter JSON in prompted harness mode.
# AGENT_PROMPTED_COMPACT_JSON=true
# Native harness: force tool calls only. Keep false for best provider compatibility.
# AGENT_TOOL_CHOICE_REQUIRED=false
# Prior chat turns sent to the model (default 8).
# AGENT_HISTORY_TURNS=8
# When > 0, fetch deeper history then trim (see chat_service.history_for_agent).
# AGENT_THREAD_COMPACT_AFTER_PAIRS=0
# OpenClaw-style: LLM turn to persist memories before trimming history (default on).
# AGENT_MEMORY_FLUSH_ENABLED=true
# AGENT_MEMORY_FLUSH_MAX_STEPS=8
# AGENT_MEMORY_FLUSH_MAX_TRANSCRIPT_CHARS=16000
# Telegram bot (optional). Webhook: POST /api/v1/telegram/webhook/{TELEGRAM_WEBHOOK_SECRET}
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# Dev only: skip startup schema probe (avoid exit when Postgres is intentionally down).
# AQUILA_SKIP_SCHEMA_PROBE=0
# Expose POST /api/v1/channels/gateway/deliver (requires JWT). Default off.
# AGENT_CHANNEL_GATEWAY_ENABLED=false
# Harness: non-web agent turns (gateway, heartbeat, future automation) use the compact tool palette.
# AGENT_NON_CHAT_USES_COMPACT_PALETTE=true
# Optional: override max tool steps (defaults to AGENT_MAX_TOOL_STEPS) — unset = use default.
# AGENT_HEARTBEAT_MAX_TOOL_STEPS=
# AGENT_CHANNEL_INBOUND_MAX_TOOL_STEPS=
# AGENT_AUTOMATION_MAX_TOOL_STEPS=
# Inject the async user context snapshot in web chat (more context, more tokens). Default off.
# AGENT_INJECT_USER_CONTEXT_IN_CHAT=false
# User context snapshot: LLM compression when refresh runs (post-consolidation / throttled post-turn).
# AGENT_USER_CONTEXT_OVERVIEW_LLM_ENABLED=true
# AGENT_USER_CONTEXT_REFRESH_MIN_MINUTES=180
# Per-user canonical memory (MEMORY.md, USER.md) and rubric.
# For clean git state in local dev, point this to a git-ignored path (compose sets /app/.local_data).
# AQUILA_USER_DATA_DIR=backend/.local_data
# Post-turn default is committee; see docs/AGENTIC_MEMORY.md
# AGENT_MEMORY_POST_TURN_MODE=committee
# AGENT_MEMORY_CONSOLIDATION_ENABLED=true
# AGENT_MEMORY_CONSOLIDATION_MINUTES=360
# Optional: custom agent workspace (SOUL.md, AGENTS.md). Default: backend/agent_workspace/
# AQUILA_WORKSPACE_DIR=/path/to/workspace
# Optional: custom skills root (see docs/SKILLS.md). Default: backend/skills/
# AQUILA_SKILLS_DIR=/path/to/skills
# EMAIL_INGEST_AUTO_CREATE_DEALS=true

# --- Inbound noise filter (proactive layer) ---
# Controls whether every ingested email/calendar event spawns a chat thread +
# agent run + push, or only the ones the filter classifies as actionable.
# Modes: off | permissive | balanced (default) | strict.
# INBOUND_FILTER_MODE=balanced
# INBOUND_FILTER_LLM=true
# INBOUND_FILTER_BURST_PER_HOUR=20

# --- Redis (required for ARQ worker: OAuth state + optional agent heartbeat) ---
REDIS_URL=redis://redis:6379/0

# --- Agent heartbeat (ARQ worker, see backend/app/worker.py) ---
# Default off. When enabled, runs a short agent turn on a schedule for each active user.
# AGENT_HEARTBEAT_ENABLED=false
# AGENT_HEARTBEAT_MINUTES=15
# Max heartbeat runs per user per hour (0 = no cap).
# AGENT_HEARTBEAT_BURST_PER_HOUR=20
# When true, heartbeat prompt tells the model to scan Gmail (high Gmail API usage). Default false.
# AGENT_HEARTBEAT_CHECK_GMAIL=false

# --- Google OAuth (optional legacy fallback only) ---
# UI path: Settings → External connectors. Leave empty when using the in-app form.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Used only when the database has no "public URL" saved yet (prefer setting Public URL in the UI).
GOOGLE_OAUTH_REDIRECT_BASE=http://localhost:8000
OAUTH_POST_AUTH_REDIRECT=http://localhost:3002/settings

# --- Microsoft Graph OAuth (optional legacy fallback only) ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
